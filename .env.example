# Copy to .env.local and fill in your Stripe keys (test keys are fine for dev).
# Get them at https://dashboard.stripe.com/test/apikeys

# Secret key — server only, NEVER expose to the client.
STRIPE_SECRET_KEY=sk_test_...

# The site's own base URL, used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Webhook signing secret — verifies that webhook calls genuinely come from
# Stripe. For local dev, run `stripe listen --forward-to localhost:3000/api/webhook`
# and paste the printed whsec_... here. In prod, get it from the Dashboard when
# you create the webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...
